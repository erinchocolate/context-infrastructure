# Environment
.env
.venv/
__pycache__/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Temp
tmp_*/
*.tmp

# Tools — generated state files (contain internal IDs, not for version control)
tools/.confluence_page_map.json
tools/.confluence_pull_versions.json

# Projects — 所有项目内容含公司内部信息，不上传，保留目录结构
projects/**
!projects/**/
!projects/**/.gitkeep

# Daily log, research, learning & memory — 同上
contexts/daily_log/*
!contexts/daily_log/.gitkeep
contexts/research/*
!contexts/research/.gitkeep
contexts/learning/*
!contexts/learning/.gitkeep
contexts/memory/*
!contexts/memory/.gitkeep
