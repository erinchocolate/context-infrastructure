# Environment
.env
.venv/
__pycache__/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Temp
tmp_*/
*.tmp

# Tools — 生成的状态文件（含内部 ID，不入版本控制）
03 refined/tools/confluence/.confluence_page_map.json
03 refined/tools/confluence/.confluence_pull_versions.json

# 01 raw — 原始输入，本地私密内容，不上传，保留目录结构
01 raw/**
!01 raw/**/
!01 raw/**/.gitkeep

# 02 trusted — 提炼后的观察与反思，本地私密内容，不上传，保留目录结构
02 trusted/**
!02 trusted/**/
!02 trusted/**/.gitkeep

# projects — 含公司内部信息，不上传，保留目录结构
projects/**
!projects/**/
!projects/**/.gitkeep

# archive — 归档内容，不上传，保留目录结构
archive/**
!archive/**/
!archive/**/.gitkeep
